{
  "ConnectionStrings": {
    "Sqlite": "Data Source=E:/BingWallpaper/BingWallpaper.db"
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Async",
      "Serilog.Sinks.File"
    ],
    "Override": {
      "Microsoft": "Warning",
      "System": "Warning"
    },
    "MinimumLevel": "Debug",
    "WriteTo": [
      {
        "Name": "Async",
        "Args": {
          "configure": [
            {
              "Name": "File",
              "Args": {
                "path": "E:/BingWallpaper/Logs/Log-.txt",
                "rollingInterval": "Day",
                "retainedFileCountLimit": 30
              },
              "restrictedToMinimumLevel": "Information"
            }
          ]
        }
      }
    ]
  },
  "AppSettings": {
    "ApplicationName": "BingWallpaper",
    "BaseDirectory": "E:/BingWallpaper",
    "LastDownloadDate": ""
  }
}
